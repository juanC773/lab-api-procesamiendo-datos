{
  "redirects": [
    {
      "source": "/",
      "destination": "/recommendations",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/recommendations",
      "destination": "/api/recommendations"
    },
    {
      "source": "/recommendations/:user_id",
      "destination": "/api/recommendations/:user_id"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "includeFiles": "data/**"
    }
  }
}
